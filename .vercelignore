# Vercel runs `vite build` from src/ + public/ — exclude everything not needed at deploy,
# which also keeps the upload under Vercel's 15k-file limit (repo has ~39k files otherwise:
# node_modules, scripts/_cache, exports, unity/Library, .git, etc.).
node_modules
.git
dist
scripts
exports
unity
docs
plans
tests
npc-staging
.playwright-mcp
.agents
*.log
# NOTE: do NOT add a global *.usdz/*.blend ignore — src/assets/couchy.usdz is imported by the
# app (src/engine/interior.js). exports/ + unity/ (the big .usdz/.blend artifacts) are already
# excluded above as whole directories.
tmp-*.png
tmp_*.cjs
char-*.jpeg
dahilg-*.jpeg
nibblers-*.jpeg
visual-*.jpeg
