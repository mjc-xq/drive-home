{
  "name": "dahill-3d",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "1840 Dahill Lane — interactive 3D neighborhood with Drive and Scoop mini-games",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "dahilg:build": "node scripts/build_dahilg.mjs",
    "dahilg:mac": "node scripts/build_dahilg.mjs --from=unitybuild --mac",
    "build:dahilg-assets": "node scripts/build_dahilg_assets.mjs",
    "build:dahilg-unity-assets": "node scripts/build_dahilg_unity_assets.mjs",
    "build:minimap": "node scripts/build_minimap.mjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.14.0",
    "@mapbox/vector-tile": "^3.0.0",
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@react-three/rapier": "1.5.0",
    "3d-tiles-renderer": "^0.4.28",
    "jotai": "2.20.1",
    "pbf": "^5.1.0",
    "postprocessing": "^6.39.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0"
  },
  "overrides": {
    "three": "$three"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@vitejs/plugin-react": "^4.3.4",
    "draco3dgltf": "^1.5.7",
    "meshoptimizer": "^1.1.1",
    "sharp": "^0.33.5",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^2.1.8"
  }
}
