{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "git lfs install && git lfs pull && npm run build",
  "rewrites": [
    { "source": "/drive", "destination": "/index.html" },
    { "source": "/drive/", "destination": "/index.html" },
    { "source": "/scoop", "destination": "/index.html" },
    { "source": "/scoop/", "destination": "/index.html" },
    { "source": "/da-hilg", "destination": "/index.html" },
    { "source": "/da-hilg/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/unity/da-hilg/Build/(.*)\\.data\\.unityweb",
      "headers": [
        { "key": "Content-Encoding", "value": "br" },
        { "key": "Content-Type", "value": "application/octet-stream" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity/da-hilg/Build/(.*)\\.wasm\\.unityweb",
      "headers": [
        { "key": "Content-Encoding", "value": "br" },
        { "key": "Content-Type", "value": "application/wasm" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity/da-hilg/Build/(.*)\\.framework\\.js\\.unityweb",
      "headers": [
        { "key": "Content-Encoding", "value": "br" },
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity/da-hilg/StreamingAssets/(.*)\\.glb",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/unity/da-hilg/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/unity/da-hilg/Build/da-hilg.loader.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
