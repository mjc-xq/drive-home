node_modules/
dist/
# exports/ is the level generator's working dir. Track the generated per-level LEVEL folders
# (exports/<slug>/ — versioned level masters; big *.level.glb via LFS, see .gitattributes) but ignore
# the loose scratch/legacy clutter in the root. Verification RENDERS are ignored; logs are kept.
exports/*
!exports/dahill/
!exports/canyon/
!exports/stanton/
!exports/meemaw/
!exports/xq/
exports/**/_renders/
exports/**/*.verify.jpg
exports/**/*.verify.png
# regenerable bake OUTPUTS inside the tracked level folders (large atlases/masks, rebuilt every bake) — keep ignored
exports/*/_ground/
exports/*/_facades/
exports/*/*.vegetation.json
exports/*/*.surface_class*.png
# large re-fetchable SOURCE imagery (the master GLB already bakes it in) — too big to track as git blobs
exports/**/*_sv_wide/
exports/**/sv_facades/
exports/*/google_aerial.jpg
scripts/.venv/
scripts/_cache/
.DS_Store
.env
.env.*
!.env.example

# local verification artifacts
.playwright-mcp/
veh-*.jpeg
parked-look*.jpeg
scoop-*.jpeg
drive-*.jpeg

# scratch screenshots + temp scripts at repo root (debug only)
/*.jpeg
/*.png
/tmp-*
/tmp_*
/.playwright-mcp/
.vercel

