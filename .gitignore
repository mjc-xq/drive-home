# level.glb is 138MB > GitHub's 100MB limit). Streamed levels ship from public/unity StreamingAssets.
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/level.glb
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/level.glb.meta
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/canyon.glb
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/canyon.glb.meta
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/stanton.glb
unity/DaHilgUnity/Assets/DaHilg/Art/Levels/stanton.glb.meta
